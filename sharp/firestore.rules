rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEventOwner() {
      return isAuthenticated() && resource.data.organizerId == request.auth.uid;
    }

    function validEventTimeRange() {
      return request.resource.data.startTime < request.resource.data.endTime;
    }

    function canCreateEvent() {
      return isAuthenticated()
        && (isAdmin() || request.resource.data.organizerId == request.auth.uid)
        && validEventTimeRange()
        // Only admins can directly create an already-approved event.
        && (request.resource.data.status != 'approved' || isAdmin());
    }

    function canUpdateEvent() {
      return isAuthenticated() && (
        isAdmin()
        || (
          isEventOwner()
          && request.resource.data.organizerId == resource.data.organizerId
          // Organizers cannot self-approve by writing status=approved.
          && !(request.resource.data.status == 'approved' && resource.data.status != 'approved')
        )
        || (
          // Allow anyone to update registration/attendance counts if that's all they are changing
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registeredCount', 'attendanceCount'])
        )
      );
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // EVENTS
    match /events/{eventId} {
      allow read: if true;
      allow create: if canCreateEvent();
      allow update: if canUpdateEvent();
      allow delete: if isAdmin() || isEventOwner();
    }

    // VENUES
    match /venues/{venueId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // REGISTRATIONS
    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // CERTIFICATES & TEMPLATES
    match /certificates/{certId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /certificateTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // TASKS
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // FEEDBACK
    match /feedback/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ACTIVITY LOGS
    match /activityLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // SETTINGS
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
